# EcoTrace server configuration — copy to `.env` and adjust as needed.
# Every variable is validated at startup (server/src/lib/env.ts).

# development | test | production
NODE_ENV=development

# Port the Express API listens on
PORT=3000

# SQLite database file (created automatically; use :memory: for ephemeral)
DB_PATH=server/data/ecotrace.db

# Allowed browser origin for CORS (the Vite dev server by default)
CORS_ORIGIN=http://localhost:5173
